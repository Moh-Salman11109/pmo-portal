# ── Data Source ──────────────────────────────────────────────────
# Set to "false" to connect to SharePoint. Any other value (or omit) = mock mode.
VITE_USE_MOCK=true

# ── SharePoint Site URL ──────────────────────────────────────────
# Full URL of your SharePoint site (no trailing slash)
VITE_SP_SITE_URL=https://yourcompany.sharepoint.com/sites/pmo

# ── SharePoint List Names ────────────────────────────────────────
# Override if your list names differ from the defaults
VITE_SP_PROJECTS_LIST=PMO_Projects
VITE_SP_DEPARTMENTS_LIST=PMO_Departments

# ── Pagination ───────────────────────────────────────────────────
# Max items per SP REST page (default 500, SP hard max is 5000)
VITE_SP_PAGE_SIZE=500
