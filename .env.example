# ─── Data source ─────────────────────────────────────────────────────────────
# true  → mock data, no authentication required (local development)
# false → live SharePoint, Microsoft 365 login required
VITE_USE_MOCK=true

# ─── SharePoint ───────────────────────────────────────────────────────────────
# Full URL of your SharePoint site — no trailing slash
VITE_SP_SITE_URL=https://yourcompany.sharepoint.com/sites/pmo
# GRC Dashboard SharePoint site (separate from PMO site)
VITE_GRC_SP_SITE_URL=https://yourcompany.sharepoint.com/sites/GRC-Dashboard
VITE_SP_PROJECTS_LIST=PMO_Projects
VITE_SP_DEPARTMENTS_LIST=PMO_Departments
VITE_SP_PAGE_SIZE=500

# ─── Azure AD / Entra ID ─────────────────────────────────────────────────────
# Obtain from: Azure Portal → App registrations → your app → Overview
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Redirect URI registered in the Azure App Registration.
# Leave blank to auto-detect from window.location.origin (works for most deployments).
# Must exactly match one of the Redirect URIs configured in Azure AD.
# Examples:
#   https://pmo.yourcompany.com          ← internal server
#   https://pmo.azurestaticapps.net      ← Azure Static Web Apps
#   http://localhost:5173                ← local dev (only when testing live SP)
VITE_AZURE_REDIRECT_URI=

# ─── Approval routing ────────────────────────────────────────────────────────
# Emails shown in My Actions when a request/gate is pending with PMO or Finance.
# Leave blank to hide the email link; routing by status label still works.
VITE_PMO_COORDINATOR_EMAIL=pmo@yourcompany.com
VITE_FINANCE_EMAIL=finance@yourcompany.com
VITE_STRATEGY_EMAIL=strategy@yourcompany.com
